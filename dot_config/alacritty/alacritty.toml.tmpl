[env]
TERM = "xterm-256color"
WINIT_X11_SCALE_FACTOR = "1"

[general]
live_config_reload = true
working_directory = "None"
import = [
    {{- if eq .colorgen "noctalia" }}
    "~/.config/alacritty/themes/noctalia.toml",
    {{- else if eq .colorgen "dms" }}
    "~/.config/alacritty/dank-theme.toml",
    {{- else }}
    "~/.config/alacritty/themes/default.toml",
    {{- end }}
]

[window]
dynamic_padding = true
decorations = "full"
title = "Alacritty"
opacity = 0.8
decorations_theme_variant = "Dark"
dimensions = { columns = 100, lines = 30 }
class = { instance = "Alacritty", general = "Alacritty" }

[scrolling]
history = 10000
multiplier = 3

[cursor]
style = "Underline"
unfocused_hollow = true
thickness = 0.15

[mouse]
hide_when_typing = true

[selection]
semantic_escape_chars = ",│`|:\"' ()[]{}<>\t"
save_to_clipboard = false

[bell]
duration = 0

[font]
size = 12
normal = { family = "JetBrainsMonoNL Nerd Font", style = "Regular" }
bold   = { family = "JetBrainsMonoNL Nerd Font", style = "Bold" }
italic = { family = "JetBrainsMonoNL Nerd Font", style = "Italic" }

[keyboard]
bindings = [
  { key = "C",       mods = "Control|Shift", action = "Copy"  },
  { key = "V",       mods = "Control|Shift", action = "Paste" },
  { key = "N",       mods = "Control|Shift", action = "SpawnNewInstance" },
  { key = "Plus",    mods = "Control",       action = "IncreaseFontSize" },
  { key = "Minus",   mods = "Control",       action = "DecreaseFontSize" },
  { key = "Key0",    mods = "Control",       action = "ResetFontSize"    },
  { key = "Enter",   mods = "Shift",         chars = "\n" },
  { key = "L",       mods = "Control",       action = "ClearLogNotice" },
  { key = "Up",      mods = "Shift|Alt",     action = "ScrollPageUp" },
  { key = "Down",    mods = "Shift|Alt",     action = "ScrollPageDown" },
  { key = "Left",    mods = "Shift|Alt",     action = "ScrollToTop" },
  { key = "Right",   mods = "Shift|Alt",     action = "ScrollToBottom" },
  { key = "F",       mods = "Control|Shift", action = "SearchForward" },
  { key = "B",       mods = "Control|Shift", action = "SearchBackward" },
]
