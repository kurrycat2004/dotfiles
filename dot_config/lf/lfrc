set shellopts '-eu'

set hidden true
set icons true
set number true
set previewer ~/.config/lf/lf-previewer.sh
set tabstop 4
set incsearch true
set wrapscroll true

set mouse true
map <m-up> up
map <m-down> down
map <m-1> open
map <m-2> updir

map e ${{ nemo $f }}

map <esc> quit

cmd open &{{
    case $(file --mime-type -Lb $f) in
        text/*) lf -remote "send $id \$$EDITOR \$fx";;
        *) for f in $fx; do $OPENER $f > /dev/null 2> /dev/null & done;;
    esac
}}