{
    "include": [
        "modules/battery.jsonc",    // battery
        "modules/clock.jsonc",      // clock, clock#1, clock#2, clock#3
        "modules/media.jsonc",      // mpris#state, mpris#meta, custom/media_next
        "modules/network.jsonc",    // network
        "modules/seperators.jsonc", // custom/sp1, custom/sp2
        "modules/weather.jsonc",    // custom/weather
        "modules/yt-music.jsonc"    // custom/yt-like, custom/yt-dislike
    ],

    "custom/rofi": {
        "format": "пѓ‰",
        "tooltip": false,
        "on-click-right": "nwg-drawer",
        "on-click": "wofi --show run",
        "on-click-middle": "pkill -9 wofi"
    },
    "custom/screenshot_t":{
        "format":"пЂ° ",
        "on-click": "{{ .screenshotFull }}",
        "on-click-right": "{{ .screenshotArea }}"
    },

    "temperature": {
        // "thermal-zone": 1,
        "interval": 4,
        //"hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "п‹‰ {temperatureC}В°C",
        "format-critical": "пЃ±  {temperatureC}В°C",
        "format": "{icon}  {temperatureC}В°C",
        "format-icons": ["пќ«", "п‹‰", "пќ©"],
        "max-length": 7,
        "min-length": 7,
        "on-click": "xsensors"
    },

    "memory": {
        "interval": 30,
        "format": "п‹›  {used:0.2f} / {total:0.0f} GB",
        "on-click": "{{ .terminal }} {{ .terminalArgs }} btop"
    },

    "custom/storage": {
        "format": "п‚  {}",
        "format-alt": "{percentage}% п‚ ",
        "format-alt-click": "click-right",
        "return-type": "json",
        "interval": 60,
        "exec": "~/.config/waybar/scripts/storage.sh"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-alt": "{percent}% {icon}",
        "format-alt-click": "click-right",
        //"format-icons": ["пѓ«", "п ґ"],
        "format-icons": ["п†…", "п„‘"],
        "on-scroll-down": "brightnessctl s 5%-",
        "on-scroll-up": "brightnessctl s +5%"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пЃ®",
            "deactivated": "пЃ°"
        },
        "tooltip": "true"
    },

    "custom/pacman": {
        "format": "<big>фЏ†І</big>  {}",
        "interval": 3600,                     // every hour
        "exec": "checkupdates | wc -l",       // # of updates
        "exec-if": "exit 0",                  // always run; consider advanced run conditions
        "on-click": "{{ .terminal }} {{ .terminalArgs }} 'yay'; pkill -SIGRTMIN+8 waybar", // update system
        "signal": 8,
        "max-length": 5,
        "min-length": 3
    },

    "custom/power": {
        "format": " у°ђҐ ",
        "tooltip": false,
        "on-click": "wlogout"
    },

    "custom/gammastep": {
      "interval": 5,
      "return-type": "json",
      "exec": {
        "pre": "if unit_status=\"$(systemctl --user is-active gammastep)\"; then\nstatus=\"$unit_status ($(journalctl --user -u gammastep.service -g 'Period: ' | tail -1 | cut -d ':' -f6 | xargs))\"\nelse\nstatus=\"$unit_status\"\nfi",
        "alt": "${status:-inactive}",
        "tooltip": "Gammastep is $status",
      },
      "format": "{icon}",
      "format-icons": {
        "activating": "у°ЃЄ ",
        "deactivating": "у°ЃЄ ",
        "inactive": "? ",
        "active (Night)": "п†† ",
        "active (Nighttime)": "п†† ",
        "active (Transition (Night)": "п†† ",
        "active (Transition (Nighttime)": "п†† ",
        "active (Day)": "оЊЌ ",
        "active (Daytime)": "оЊЌ ",
        "active (Transition (Day)": "оЊЌ ",
        "active (Transition (Daytime)": "оЊЌ ",
      },
      "on-click": "systemctl --user is-active gammastep && systemctl --user stop gammastep || systemctl --user start gammastep",
    },

    "cpu": {
        "interval": 1,
        //"format": "п‹› {}%", // Icon: microchip
        "format": "{max_frequency}GHz <span color=\"darkgray\">| {usage}%</span>",
        "max-length": 13,
        "min-length": 13
    },

    "mpd": {
        "max-length": 25,
        "format": "<span foreground='#bb9af7'>пЂЃ</span> {title}",
        "format-paused": "пЂЃ {title}",
        "format-stopped": "<span foreground='#bb9af7'>пЂЃ</span>",
        "format-disconnected": "",
        "on-click": "mpc --quiet toggle",
        "on-click-right": "mpc update; mpc ls | mpc add",
        "on-click-middle": "{{ .terminal }} {{ .terminalArgs }} ncmpcpp",
        "on-scroll-up": "mpc --quiet prev",
        "on-scroll-down": "mpc --quiet next",
        "smooth-scrolling-threshold": 5,
        "tooltip-format": "{title} - {artist} ({elapsedTime:%M:%S}/{totalTime:%H:%M:%S})"
    },

    "custom/title": {
        "format": "{}",
        "interval": 0,
        "return-type": "json",
        //"max-length": 35,
        "tooltip": false
    },

    "hyprland/workspaces": {
        "all-outputs": true,
        "format": "{name}",
        "format-icons": {
            "1": "дёЂ",
            "2": "дєЊ",
            "3": "дё‰",
            "4": "е››",
            "5": "дє”",
            "6": "е…­",
            "7": "дёѓ",
            "8": "е…«",
            "9": "д№ќ",
            "10": "еЌЃ",
        },
        "on-scroll-up": "hyprctl dispatch workspace e+1 1>/dev/null",
        "on-scroll-down": "hyprctl dispatch workspace e-1 1>/dev/null",
        "sort-by-number": true,
        "active-only": false,
    },

    "hyprland/window": {
        "max-length": 100,
        "separate-outputs": true
    },

    "pulseaudio": {
        "scroll-step": 3, // %, can be a float
        "format": "{icon} {volume}% {format_source}",
        "format-bluetooth": "{volume}% {icon}пЉ” {format_source}",
        "format-bluetooth-muted": "пљ© {icon}пЉ” {format_source}",
        "format-muted": "пљ© {format_source}",
        //"format-source": "{volume}% п„°",
        //"format-source-muted": "п„±",
        "format-source": "п„°",
        "format-source-muted": "п„±",
        "format-icons": {
            "headphone": "пЂҐ",
            "hands-free": "п–ђ",
            "headset": "п–ђ",
            "phone": "п‚•",
            "portable": "п‚•",
            "car": "п†№",
            "default": ["пЂ¦", "пЂ§", "пЂЁ"]
        },
        "on-click": "pavucontrol",
        "on-click-right": "amixer sset Master toggle"
    },

    "wireplumber": {
        "on-click": "pavucontrol",
        "on-click-right": "amixer sset Master toggle 1>/dev/null",
        //on-click: "${wpctl} set-mute @DEFAULT_AUDIO_SINK@ toggle";
        //on-scroll-down: "${wpctl} set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 0.04+";
        //on-scroll-up: "${wpctl} set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 0.04-";
        "format": "<span foreground='#fab387'>{icon}</span>  {volume}%",
        "format-muted": "пљ© ",
        "format-source": "п„°",
        "format-source-muted": "п„±",
        //"format-muted": "<span foreground='#fab387'>п‘¦ </span>",
        //"format-icons": [ "<span foreground='#fab387'>пЂЁ</span>" ]
        "format-icons": {
            "headphone": "пЂҐ ",
            "hands-free": "п–ђ ",
            "headset": "п–ђ ",
            "phone": "п‚• ",
            "portable": "п‚• ",
            "car": "п†№ ",
            "default": ["пЂ¦ ", "пЂ§ ", "пЂЁ "]
        },
    },

    "tray": {
        "icon-size": 15,
        "spacing": 5
    }
}
